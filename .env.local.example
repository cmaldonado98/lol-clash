# ── Supabase ────────────────────────────────────────────────────
# Obtén estos valores en: https://supabase.com/dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Proyectos nuevos de Supabase usan "publishable key" (antes llamado "anon key")
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx
# Si tienes un proyecto antiguo, usa esto en su lugar:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
